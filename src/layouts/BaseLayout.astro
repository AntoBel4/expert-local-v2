---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title,
  description = 'Expert en réputation Google pour commerçants et artisans locaux. Obtenez 10 avis Google 5★ en 10 jours.',
  noindex = false,
  ogImage = '/images/og-image-2026.webp',
} = Astro.props;

const siteUrl = 'https://expert-local.fr';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="fr" style="scroll-behavior: smooth;">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`${canonicalUrl}${!canonicalUrl.endsWith('/') ? '/' : ''}`} />

  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Fonts: preconnect + non-blocking load -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL@20..48,100..700,0..1&display=swap" rel="stylesheet" />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content="https://expert-local.fr/images/og-image-2026.webp" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="628" />
<meta property="og:image:alt" content="Expert-Local.fr — Plus d'avis Google. Plus de clients." />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Expert Local" />
<meta property="og:locale" content="fr_FR" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content="https://expert-local.fr/images/og-image-2026.webp" />
<meta name="twitter:image:alt" content="Expert-Local.fr — Plus d'avis Google. Plus de clients." />

  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body>
  <header class="header">
    <div class="container">
      <a href="/" class="logo">Expert Local</a>
      <nav class="nav">
        <a href="/blog/" class="nav-link">Blog</a>
        <a href="#diagnostic" class="btn btn--header">
          <span class="material-symbols-outlined">gps_fixed</span> Diagnostic
        </a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
