---
/**
 * go.astro — Hub de communication stratégique (Mobile-First)
 * Page autonome, sans Header/Footer du site principal.
 * Conçue pour être partagée : carte de visite, QR code, signature email, réseaux.
 */
const siteUrl = 'https://expert-local.fr';
const canonicalUrl = `${siteUrl}/go/`;
const title = 'Antoine Estarellas — Expertise en Visibilité Locale | Chartres & Eure-et-Loir';
const description = 'Praticien du terrain basé à Chartres. J\'accompagne les artisans et commerçants du 28 pour transformer leur présence Google en moteur de croissance.';
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="noindex, nofollow" />

  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}/images/og-image-2026.webp`} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="profile" />
  <meta property="og:locale" content="fr_FR" />

  <style>
    /* ── Reset ── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    /* ── Tokens (subset du design system M3 Dark) ── */
    :root {
      --color-bg:           #10131a;
      --color-surface:      #1d2027;
      --color-surface-high: #272a31;
      --color-primary:      #ffb595;
      --color-primary-ctr:  #ff7f3f;
      --color-primary-glow: rgba(255, 127, 63, 0.15);
      --color-on-primary:   #351000;
      --color-secondary:    #51df9c;
      --color-on-surface:   #e0e2ec;
      --color-muted:        #9aa5b4;
      --color-dim:          #6c7a8d;
      --color-border:       rgba(255, 255, 255, 0.08);
      --font-body:    'Inter', system-ui, sans-serif;
      --font-heading: 'Plus Jakarta Sans', system-ui, sans-serif;
      --radius-lg: 16px;
      --radius-xl: 20px;
      --radius-full: 50px;
      --shadow-glow: 0 0 30px rgba(255, 127, 63, 0.2);
    }

    html { -webkit-font-smoothing: antialiased; }
    body {
      font-family: var(--font-body);
      background: var(--color-bg);
      color: var(--color-on-surface);
      min-height: 100dvh;
      display: flex;
      justify-content: center;
      padding: 2rem 1rem 3rem;
    }

    /* ── Container ── */
    .hub {
      width: 100%;
      max-width: 440px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }

    /* ── Avatar + Identité ── */
    .hub-identity { text-align: center; }
    .hub-avatar {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      border: 3px solid var(--color-primary);
      object-fit: cover;
      margin-bottom: 1rem;
      box-shadow: var(--shadow-glow);
    }
    .hub-name {
      font-family: var(--font-heading);
      font-size: 1.5rem;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 0.25rem;
    }
    .hub-title {
      font-size: 0.875rem;
      color: var(--color-primary);
      font-weight: 600;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }
    .hub-location {
      font-size: 0.8rem;
      color: var(--color-dim);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      margin-bottom: 1rem;
    }
    .hub-location svg { width: 14px; height: 14px; stroke: var(--color-dim); }
    .hub-bio {
      font-size: 0.95rem;
      line-height: 1.65;
      color: var(--color-muted);
      max-width: 380px;
      margin: 0 auto;
    }
    .hub-bio strong { color: var(--color-on-surface); font-weight: 600; }

    /* ── Stat bar ── */
    .hub-stats {
      display: flex;
      justify-content: center;
      gap: 2rem;
      padding: 1rem 0;
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      width: 100%;
    }
    .hub-stat { text-align: center; }
    .hub-stat-num {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--color-primary);
    }
    .hub-stat-label {
      font-size: 0.7rem;
      color: var(--color-dim);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-top: 0.15rem;
    }

    /* ── Boutons ── */
    .hub-links {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      width: 100%;
    }
    .hub-link {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 1rem 1.25rem;
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      color: var(--color-on-surface);
      text-decoration: none;
      font-size: 0.95rem;
      font-weight: 500;
      transition: all 200ms ease;
      position: relative;
    }
    .hub-link:hover, .hub-link:focus-visible {
      border-color: var(--color-primary);
      background: var(--color-surface-high);
      box-shadow: var(--shadow-glow);
      transform: translateY(-1px);
    }
    .hub-link svg {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      stroke: var(--color-primary);
    }
    .hub-link-arrow {
      margin-left: auto;
      width: 16px;
      height: 16px;
      stroke: var(--color-dim);
    }
    .hub-link:hover .hub-link-arrow { stroke: var(--color-primary); }

    /* Variante CTA principal */
    .hub-link--primary {
      background: linear-gradient(135deg, var(--color-primary-ctr), #e86a20);
      border-color: transparent;
      color: var(--color-on-primary);
      font-weight: 700;
    }
    .hub-link--primary svg { stroke: var(--color-on-primary); }
    .hub-link--primary .hub-link-arrow { stroke: rgba(53, 16, 0, 0.5); }
    .hub-link--primary:hover {
      box-shadow: 0 8px 24px rgba(255, 127, 63, 0.35);
      transform: translateY(-2px);
    }

    /* Variante WhatsApp */
    .hub-link--whatsapp { border-color: rgba(81, 223, 156, 0.2); }
    .hub-link--whatsapp svg { stroke: var(--color-secondary); }
    .hub-link--whatsapp:hover { border-color: var(--color-secondary); box-shadow: 0 0 20px rgba(81, 223, 156, 0.15); }

    /* ── Section séparateur ── */
    .hub-section {
      width: 100%;
      padding-top: 0.5rem;
    }
    .hub-section-label {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-dim);
      margin-bottom: 0.75rem;
      padding-left: 0.25rem;
    }

    /* ── Footer ── */
    .hub-footer {
      text-align: center;
      padding-top: 1rem;
      border-top: 1px solid var(--color-border);
      width: 100%;
    }
    .hub-footer-link {
      font-size: 0.8rem;
      color: var(--color-dim);
      text-decoration: none;
      transition: color 200ms;
    }
    .hub-footer-link:hover { color: var(--color-primary); }
    .hub-footer-copy {
      font-size: 0.7rem;
      color: var(--color-dim);
      margin-top: 0.5rem;
      opacity: 0.6;
    }
  </style>
</head>
<body>

  <div class="hub">

    <!-- ── Identité ── -->
    <div class="hub-identity">
      <img
        src="/photo-profil.jpg"
        alt="Antoine Estarellas"
        class="hub-avatar"
        width="96"
        height="96"
        loading="eager"
      />
      <h1 class="hub-name">Antoine Estarellas</h1>
      <p class="hub-title">Expertise en Visibilite Locale</p>
      <p class="hub-location">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        Chartres, Eure-et-Loir (28)
      </p>
      <p class="hub-bio">
        Praticien du terrain base a Chartres, secteur Place des Epars.
        J'accompagne les <strong>artisans et commercants du 28</strong> pour transformer
        leur presence Google en un veritable moteur de croissance.
        <strong>+130 avis generes</strong> en centre-ville pour mes clients.
      </p>
    </div>

    <!-- ── Chiffres ── -->
    <div class="hub-stats">
      <div class="hub-stat">
        <div class="hub-stat-num">130+</div>
        <div class="hub-stat-label">Avis generes</div>
      </div>
      <div class="hub-stat">
        <div class="hub-stat-num">87%</div>
        <div class="hub-stat-label">Taux de reussite</div>
      </div>
      <div class="hub-stat">
        <div class="hub-stat-num">10j</div>
        <div class="hub-stat-label">Premiers resultats</div>
      </div>
    </div>

    <!-- ── Actions principales ── -->
    <div class="hub-section">
      <div class="hub-section-label">Pour les artisans et commercants</div>
      <div class="hub-links">

        <a href="/#diagnostic" class="hub-link hub-link--primary">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          Faire le Diagnostic Gratuit
          <svg class="hub-link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

        <a href="/#offre" class="hub-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>
          Solution Visibilite Express
          <svg class="hub-link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

      </div>
    </div>

    <!-- ── Expertise & Presse ── -->
    <div class="hub-section">
      <div class="hub-section-label">Expertise et ressources</div>
      <div class="hub-links">

        <a href="/blog/urgence-plomberie-chartres/" class="hub-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
          Blog : L'Urgence et Google
          <svg class="hub-link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

        <a href="/blog/" class="hub-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Tous les articles
          <svg class="hub-link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

        <a href="mailto:contact.expertlocal@gmail.com?subject=Presse%20/%20Partenariat%20—%20Expert%20Local" class="hub-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Espace Presse et Partenaires
          <svg class="hub-link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

      </div>
    </div>

    <!-- ── Contact direct ── -->
    <div class="hub-section">
      <div class="hub-section-label">Contact direct</div>
      <div class="hub-links">

        <a href="https://wa.me/33641519177?text=Bonjour%20Antoine%2C%20je%20vous%20contacte%20depuis%20votre%20site%20Expert%20Local." class="hub-link hub-link--whatsapp" target="_blank" rel="noopener">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          Me contacter sur WhatsApp
          <svg class="hub-link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

        <a href="mailto:contact.expertlocal@gmail.com" class="hub-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          contact.expertlocal@gmail.com
          <svg class="hub-link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>

      </div>
    </div>

    <!-- ── Footer ── -->
    <footer class="hub-footer">
      <a href="/" class="hub-footer-link">expert-local.fr</a>
      <p class="hub-footer-copy">&copy; 2026 Studio Estarellas — Chartres (28)</p>
    </footer>

  </div>

</body>
</html>
