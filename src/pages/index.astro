---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "AdministrativeArea",
  "name": "Eure-et-Loir",
  "identifier": "28",
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "Centre-Val de Loire"
  }
}
</script>

<BaseLayout title="Expert Local 2026 | Obtenez 10 Avis Google 5★ en 10 Jours">

  <!-- ═══════════════════════════════════
       BARRE D'URGENCE
  ═══════════════════════════════════ -->
  <div class="urgent-bar">
    <div class="container urgent-content">
      <span class="urgent-badge">⚠️ URGENT 2026</span>
      <span class="urgent-text">Google pénalise les fiches avec moins de 10 avis récents</span>
      <a href="#diagnostic" class="urgent-cta">Vérifier mon statut →</a>
    </div>
  </div>


  <!-- ═══════════════════════════════════
       HERO
  ═══════════════════════════════════ -->
  <section class="hero" id="hero">
    <div class="container hero-grid">

      <div class="hero-content">
        <div class="authority-badge">
          <Image
            src="/photo-profil.jpg"
            alt="Antoine Estarellas"
            width={36}
            height={36}
            format="webp"
            loading="lazy"
            decoding="async"
            class="badge-avatar"
          />
          <div class="badge-info">
            <span class="badge-name">Antoine Estarellas</span>
            <span class="badge-role">Conseiller numérique · Expert Google Local</span>
          </div>
          <div class="badge-check">✓</div>
        </div>

        <h1 class="hero-title">
          Vos concurrents ont
          <span class="text-gradient">10 avis de plus</span>
          que vous.<br>
          <span class="hero-title-sub">Découvrez la faille 2026.</span>
        </h1>

        <p class="hero-subtitle">
          Les QR Codes seuls ne fonctionnent <strong class="text-coral">PLUS</strong>.
          En 2026, il faut une <span class="text-mint">méthode psychologique</span>
          qui transforme vos clients satisfaits en ambassadeurs.
        </p>

        <div class="hero-stats">
          <div class="stat"><span class="stat-num">87%</span><span class="stat-txt">de réussite</span></div>
          <div class="stat"><span class="stat-num">24-48h</span><span class="stat-txt">premiers résultats</span></div>
          <div class="stat"><span class="stat-num">15+</span><span class="stat-txt">commerces aidés</span></div>
        </div>

        <a href="#diagnostic" class="btn btn--primary btn--large hero-cta">
          🎯 Diagnostic Gratuit — 60 secondes
        </a>

        <div class="hero-trust">
          <span>✓ Testé en Eure-et-Loir</span>
          <span>✓ Méthode 2026</span>
          <span>✓ Aucun engagement</span>
        </div>
      </div>

      <div class="hero-visual">
        <div class="comparison-card card card--glass">
          <div class="comparison-header">
            <h4>Résultats réels en Eure-et-Loir</h4>
            <div class="comparison-tabs">
              <button class="tab-btn tab-btn--active" data-tab="before">AVANT</button>
              <button class="tab-btn" data-tab="after">APRÈS</button>
            </div>
          </div>
          <div class="tab-panel" id="panel-before">
            <div class="rating rating--low">
              <span class="rating-stars">★★★☆☆</span>
              <span class="rating-num">3.2</span>
            </div>
            <div class="review-count">14 avis</div>
            <div class="points">
              <div class="point point--bad"><span>❌</span><span>1 avis par mois</span></div>
              <div class="point point--bad"><span>❌</span><span>Position 5 sur Google</span></div>
              <div class="point point--bad"><span>❌</span><span>Clients ne laissent pas d'avis</span></div>
            </div>
          </div>
          <div class="tab-panel" id="panel-after" style="display: none;">
            <div class="rating rating--high">
              <span class="rating-stars">★★★★★</span>
              <span class="rating-num">4.7</span>
            </div>
            <div class="review-count">38 avis</div>
            <div class="points">
              <div class="point point--good"><span>✅</span><span>10 avis en 10 jours</span></div>
              <div class="point point--good"><span>✅</span><span>Position 1 sur Google</span></div>
              <div class="point point--good"><span>✅</span><span>+240% de visibilité</span></div>
            </div>
          </div>
          <div class="comparison-footer">
            <span>Cas réel : Salon de coiffure à Chartres</span>
          </div>
        </div>

        <div class="local-badge">
          <span>📍</span>
          <div>
            <strong>Spécialiste Eure-et-Loir</strong>
            <small>Je connais vos concurrents locaux</small>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════
       MENACE / URGENCE
  ═══════════════════════════════════ -->
  <section class="section section--dark" id="menace">
    <div class="container">
      <div class="section-header">
        <span class="section-label section-label--coral">⚠️ ALERTE 2026</span>
        <h2 class="section-title">La nouvelle règle Google qui <span class="text-coral">menace votre commerce</span></h2>
        <p class="section-subtitle">En 2026, Google a changé ses algorithmes. Voici ce que vos concurrents savent déjà :</p>
      </div>
      <div class="grid grid--3 threat-grid">
        <div class="card threat-card threat-card--critical">
          <div class="threat-icon">📉</div>
          <h3>#1 : L'effet "Local Ghost"</h3>
          <p>Les fiches avec moins de <strong>10 avis récents</strong> sont progressivement invisibilisées dans les résultats locaux.</p>
          <div class="threat-data"><span>Impact :</span><span class="data-critical">-67% de visibilité</span></div>
        </div>
        <div class="card threat-card threat-card--warning">
          <div class="threat-icon">⏰</div>
          <h3>#2 : La fenêtre des 48h</h3>
          <p>Un avis laissé dans les 48h après la prestation a 4x plus de chances d'être 5★. Après 72h, c'est trop tard.</p>
          <div class="threat-data"><span>Chance 5★ :</span><span class="data-warning">74% → 18%</span></div>
        </div>
        <div class="card threat-card threat-card--info">
          <div class="threat-icon">🤖</div>
          <h3>#3 : L'IA Google détecte</h3>
          <p>L'IA de Google détecte les avis "forcés". Seuls les avis organiques obtenus par psychologie sont valorisés.</p>
          <div class="threat-data"><span>Détection IA :</span><span class="data-info">92% précision</span></div>
        </div>
      </div>

      <div class="threat-bottom">
        <p class="threat-conclusion">
          <strong>Concrètement ?</strong> Un plombier de Dreux perdait <span class="text-coral">18 clients par mois</span> sans le savoir. Soit <strong>2 400 € de manque à gagner mensuel</strong>.
        </p>
        <a href="#diagnostic" class="btn btn--primary btn--large">Vérifier mon statut gratuitement</a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════
       VIDÉO
  ═══════════════════════════════════ -->
  <section class="video-section" id="video">
    <div class="container">
      <div class="section-header">
        <span class="section-label section-label--primary">🎬 Méthode en vidéo</span>
        <h2 class="section-title">Regardez comment nos clients passent de<br><em class="text-gradient">invisibles à incontournables</em> sur Google</h2>
        <p class="section-subtitle">78 secondes pour comprendre pourquoi vos concurrents vous devancent — et comment inverser la tendance dès demain.</p>
      </div>
      <div class="video-wrapper">
        <video class="video-player card card--glass" controls preload="metadata" poster="/video-thumbnail.webp" playsinline>
          <source src="/expert-local-video.mp4" type="video/mp4">
          Votre navigateur ne prend pas en charge la vidéo.
        </video>
      </div>
      <div class="video-trust">
        <span>🔇 Sous-titres inclus</span>
        <span>⏱️ 1 min 18 sec</span>
        <span>📍 Cas réels Eure-et-Loir</span>
        <span>🔒 Aucune inscription</span>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════
       MÉTHODE
  ═══════════════════════════════════ -->
  <section class="section" id="methode">
    <div class="container">
      <div class="section-header">
        <span class="section-label section-label--primary">🧠 La méthode</span>
        <h2 class="section-title">3 principes psychologiques.<br><span class="text-gradient">10 avis en 10 jours.</span></h2>
        <p class="section-subtitle">Ce n'est pas une question de chance. C'est une question de timing, de mots et de système.</p>
      </div>
      <div class="grid grid--3 method-grid">
        <div class="card method-card">
          <div class="method-step">1</div>
          <h3>Le bon moment</h3>
          <p class="method-concept">Le "Whaou Effect"</p>
          <p>N'attendez pas la facture. Le meilleur moment pour obtenir un avis 5★, c'est la seconde exacte où le client découvre le résultat.</p>
          <div class="method-stat">
            <span class="method-stat-num">74%</span>
            <span>de conversion dans les 48h</span>
          </div>
        </div>
        <div class="card method-card">
          <div class="method-step">2</div>
          <h3>Les bons mots</h3>
          <p class="method-concept">Scripts Psychologiques</p>
          <p>Ne dites jamais "Pouvez-vous me laisser un avis ?". Demandez des "étoiles", pas un "avis écrit". L'écrit viendra naturellement.</p>
          <div class="method-stat">
            <span class="method-stat-num">3x</span>
            <span>plus efficace qu'une demande classique</span>
          </div>
        </div>
        <div class="card method-card">
          <div class="method-step">3</div>
          <h3>Le bon système</h3>
          <p class="method-concept">Automatisation Invisible</p>
          <p>QR Codes, SMS de relance 24h, suivi — tout est automatisé. Vous n'y pensez plus, les avis arrivent seuls.</p>
          <div class="method-stat">
            <span class="method-stat-num">10x</span>
            <span>plus efficace qu'un QR seul</span>
          </div>
        </div>
      </div>
      <div style="text-align: center; margin-top: var(--space-10);">
        <a href="#diagnostic" class="btn btn--primary btn--large">Tester la méthode — Diagnostic gratuit</a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════
       OFFRE / PRICING
  ═══════════════════════════════════ -->
  <section class="section section--dark" id="offre">
    <div class="container">
      <div class="section-header">
        <span class="section-label section-label--primary">💎 Les offres</span>
        <h2 class="section-title">Choisissez votre niveau d'accompagnement</h2>
        <p class="section-subtitle">Du diagnostic gratuit à l'accompagnement complet, faites le choix qui vous correspond.</p>
      </div>
      <div class="grid grid--3 pricing-grid">

        <div class="card pricing-card">
          <div class="pricing-badge pricing-badge--free">GRATUIT</div>
          <h3>Diagnostic 2026</h3>
          <div class="pricing-price">0€</div>
          <p class="pricing-desc">Découvrez votre score de risque Google et vos 3 actions prioritaires.</p>
          <ul class="pricing-features">
            <li>✓ Score de risque personnalisé</li>
            <li>✓ Analyse de vos concurrents</li>
            <li>✓ 3 actions prioritaires</li>
            <li>✓ PDF envoyé par email</li>
          </ul>
          <a href="#diagnostic" class="btn btn--primary btn--full">Recevoir mon diagnostic</a>
        </div>

        <div class="card pricing-card pricing-card--featured">
          <div class="pricing-popular">⭐ Le plus populaire</div>
          <div class="pricing-badge pricing-badge--kit">KIT EXPRESS</div>
          <h3>La Méthode Complète</h3>
          <div class="pricing-price">49€ <span class="pricing-ttc">*</span></div>
          <p class="pricing-desc">Tout le matériel pour obtenir vos 10 premiers avis 5★ en autonomie.</p>
          <ul class="pricing-features">
            <li>✓ Tout le diagnostic gratuit</li>
            <li>✓ Scripts face-à-face prêts à l'emploi</li>
            <li>✓ Templates SMS/WhatsApp</li>
            <li>✓ Générateur de QR Code</li>
            <li>✓ Templates visuels (chevalets, stickers)</li>
            <li>✓ Masterclass vidéo</li>
            <li>✓ Plan d'action 10 jours</li>
          </ul>
          <div class="order-bump-checkbox" style="text-align: left; margin: 15px 0; padding: 10px; background: rgba(0,0,0,0.05); border-radius: 8px;">
            <label style="display: flex; gap: 10px; cursor: pointer; align-items: flex-start;">
              <input type="checkbox" id="bump-kit" name="bump" style="width: 20px; height: 20px; accent-color: var(--color-primary); margin-top: 3px;">
              <span style="font-size: 0.9em; line-height: 1.3;">
                <strong>Kit Relance+ (19€)</strong><br>
                <small>5 messages vocaux prêts à envoyer + 5 scripts SMS avancés</small>
              </span>
            </label>
          </div>
          <button class="btn btn--primary btn--full btn--large btn-checkout" data-plan="kit">Commencer maintenant</button>
        </div>

        <div class="card pricing-card">
          <div class="pricing-badge pricing-badge--pro">PACK PRO</div>
          <h3>Domination Locale</h3>
          <div class="pricing-price">179€ <span class="pricing-ttc">*</span></div>
          <p class="pricing-desc">Kit digital + matériel pro livré + appel stratégique personnalisé.</p>
          <ul class="pricing-features">
            <li>✓ Tout le Kit Express</li>
            <li>✓ Audit approfondi de votre fiche Google (8-10 pages)</li>
            <li>✓ Benchmark de vos 3 concurrents locaux</li>
            <li>✓ Appel stratégique personnalisé 45 min</li>
            <li>✓ Suivi à J+10</li>
          </ul>
          <button class="btn btn--secondary btn--full btn-checkout" data-plan="pro">Devenir PRO</button>
        </div>

      </div>
      <p class="pricing-tva-note">* TVA non applicable, article 293 B du CGI.</p>
    </div>
  </section>


  <!-- ═══════════════════════════════════
       TÉMOIGNAGES / RÉASSURANCE
  ═══════════════════════════════════ -->
  <section class="section" id="resultats">
    <div class="container">
      <div class="section-header">
        <span class="section-label section-label--primary">📊 Résultats</span>
        <h2 class="section-title">Ils ont utilisé la méthode</h2>
        <p class="section-subtitle">Des résultats concrets en Eure-et-Loir.</p>
      </div>
      <div class="grid grid--3">
        <div class="card testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">"14 avis → 38 avis en 10 jours. Ma note est passée de 3.2 à 4.7. Position 1 sur Google Maps à Chartres."</p>
          <div class="testimonial-author">
            <strong>Salon de coiffure</strong>
            <span>Chartres (28)</span>
          </div>
          <div class="testimonial-result">
            <span class="badge badge--success">+240% de visibilité</span>
          </div>
        </div>
        <div class="card testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">"Je perdais 18 clients par mois sans le savoir. Après la méthode, mes appels ont augmenté de 60% en 3 semaines."</p>
          <div class="testimonial-author">
            <strong>Plombier</strong>
            <span>Dreux (28)</span>
          </div>
          <div class="testimonial-result">
            <span class="badge badge--success">+60% d'appels entrants</span>
          </div>
        </div>
        <div class="card testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">"La méthode psychologique fonctionne vraiment. Mes clients laissent des avis sans que j'aie besoin de supplier."</p>
          <div class="testimonial-author">
            <strong>Restaurateur</strong>
            <span>Épernon (28)</span>
          </div>
          <div class="testimonial-result">
            <span class="badge badge--success">10 avis 5★ en 8 jours</span>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════
       FAQ
  ═══════════════════════════════════ -->
  <section class="section section--dark" id="faq">
    <div class="container container--narrow">
      <div class="section-header">
        <span class="section-label section-label--primary">❓ FAQ</span>
        <h2 class="section-title">Questions fréquentes</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Est-ce que ça marche pour tout type de commerce ?</summary>
          <p>Oui. La méthode repose sur la psychologie humaine universelle (principe de réciprocité). Elle fonctionne pour les coiffeurs, restaurants, plombiers, électriciens, artisans, boutiques — tout commerce qui a des clients satisfaits.</p>
        </details>
        <details class="faq-item">
          <summary>Combien de temps faut-il pour voir des résultats ?</summary>
          <p>Les premiers avis arrivent en 24 à 48h. En 10 jours, vous pouvez obtenir 10 avis 5★ si vous appliquez la méthode quotidiennement.</p>
        </details>
        <details class="faq-item">
          <summary>Est-ce que les avis obtenus sont authentiques ?</summary>
          <p>Absolument. La méthode ne crée pas de faux avis. Elle vous aide à demander au bon moment, avec les bons mots, pour que vos vrais clients partagent leur expérience.</p>
        </details>
        <details class="faq-item">
          <summary>Je n'ai aucun avis, ça peut quand même fonctionner ?</summary>
          <p>C'est justement le meilleur moment pour commencer. Notre "Cercle de Confiance" (étape 1 du plan) vous permet de solliciter 3 clients très fidèles pour démarrer en douceur.</p>
        </details>
        <details class="faq-item">
          <summary>Le diagnostic est vraiment gratuit ?</summary>
          <p>Oui, 100% gratuit, sans engagement, sans carte bancaire. Vous recevez un PDF personnalisé analysant votre fiche Google, vos concurrents et votre score de risque.</p>
        </details>
        <details class="faq-item">
          <summary>Quelle est la différence entre le Kit Express et le Pack PRO ?</summary>
          <p>Le Kit Express (49€) vous donne toute la méthode en format digital (DIY). Le Pack PRO (179€) ajoute le matériel physique imprimé livré chez vous + un appel stratégique personnalisé de 30 minutes.</p>
        </details>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════
       FORMULAIRE DIAGNOSTIC (3 ÉTAPES)
  ═══════════════════════════════════ -->
  <section class="section" id="diagnostic">
    <div class="container container--narrow">
      <div class="section-header">
        <span class="section-label section-label--primary">🎯 Diagnostic Gratuit</span>
        <h2 class="section-title">Votre diagnostic personnalisé en <span class="text-gradient">60 secondes</span></h2>
        <p class="section-subtitle">Recevez votre score de risque Google et vos actions prioritaires par email.</p>
      </div>

      <div class="diagnostic-form-wrapper card card--glass">
        <form id="diagnosticForm" class="diagnostic-form" novalidate>

          <!-- Étape 1 -->
          <div class="form-step form-step--active" data-step="1">
            <div class="step-indicator">
              <span class="step-dot step-dot--active">1</span>
              <span class="step-line"></span>
              <span class="step-dot">2</span>
              <span class="step-line"></span>
              <span class="step-dot">3</span>
            </div>
            <p class="step-question">Combien d'avis avez-vous actuellement sur Google ?</p>
            <div class="options-grid">
              <label class="option-card">
                <input type="radio" name="nb_avis" value="0-5" required>
                <div class="option-inner">
                  <span class="option-emoji">🆕</span>
                  <span class="option-text">0 à 5 avis</span>
                  <small>Je commence</small>
                </div>
              </label>
              <label class="option-card">
                <input type="radio" name="nb_avis" value="6-20">
                <div class="option-inner">
                  <span class="option-emoji">📈</span>
                  <span class="option-text">6 à 20 avis</span>
                  <small>Je veux progresser</small>
                </div>
              </label>
              <label class="option-card">
                <input type="radio" name="nb_avis" value="21+">
                <div class="option-inner">
                  <span class="option-emoji">🏆</span>
                  <span class="option-text">21+ avis</span>
                  <small>Je veux dominer</small>
                </div>
              </label>
            </div>
            <button type="button" class="btn btn--primary btn--full btn-next" data-next="2">Suivant →</button>
          </div>

          <!-- Étape 2 -->
          <div class="form-step" data-step="2">
            <div class="step-indicator">
              <span class="step-dot step-dot--done">✓</span>
              <span class="step-line step-line--done"></span>
              <span class="step-dot step-dot--active">2</span>
              <span class="step-line"></span>
              <span class="step-dot">3</span>
            </div>
            <p class="step-question">Parlez-nous de votre commerce</p>
            <div class="input-group">
              <input type="text" name="nom_commerce" placeholder="Nom de votre commerce" required class="input">
              <input type="text" name="ville" placeholder="Ville" required class="input">
              <input type="url" name="lien_google" placeholder="Lien Google Maps (facultatif)" class="input">
            </div>
            <div class="step-actions">
              <button type="button" class="btn btn--dark btn-prev" data-prev="1">← Retour</button>
              <button type="button" class="btn btn--primary btn-next" data-next="3">Suivant →</button>
            </div>
          </div>

          <!-- Étape 3 -->
          <div class="form-step" data-step="3">
            <div class="step-indicator">
              <span class="step-dot step-dot--done">✓</span>
              <span class="step-line step-line--done"></span>
              <span class="step-dot step-dot--done">✓</span>
              <span class="step-line step-line--done"></span>
              <span class="step-dot step-dot--active">3</span>
            </div>
            <p class="step-question">Où envoyer votre diagnostic personnalisé ?</p>
            <div class="input-group">
              <input type="text" name="prenom" placeholder="Votre prénom" required class="input">
              <input type="email" name="email" placeholder="votre@email-professionnel.fr" required class="input">
            </div>
            <button type="submit" class="btn btn--primary btn--full btn--large btn-submit">
              ⚡ Recevoir mon diagnostic gratuit
            </button>
            <div class="privacy-note">
              🔒 Zéro spam. Vous recevrez votre PDF personnalisé + 1 email de suivi.
            </div>
            <div class="step-actions">
              <button type="button" class="btn btn--dark btn-prev" data-prev="2">← Retour</button>
            </div>
          </div>

          <!-- Message de confirmation (caché par défaut) -->
          <div class="form-success" id="formSuccess" style="display: none;">
            <div class="success-icon">✅</div>
            <h3>Diagnostic en cours de création !</h3>
            <p>Nous analysons votre fiche Google en ce moment. Vous recevrez votre PDF personnalisé par email dans les prochaines minutes.</p>
          </div>

        </form>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════
       CTA FLOTTANT
  ═══════════════════════════════════ -->
  <div class="floating-cta" id="floatingCta">
