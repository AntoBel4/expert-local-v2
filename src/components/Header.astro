---
/**
 * Header.astro — Navigation sticky glassmorphism M3
 */
---

<header class="site-header" id="site-header">
  <div class="container">
    <nav class="nav">
      <a href="/" class="nav-logo" aria-label="Expert Local - Accueil">
        Expert<span class="nav-logo-accent">Local</span>.fr
      </a>
      <div class="nav-actions">
        <a href="#diagnostic" class="btn btn--primary btn--header">
          Diagnostic gratuit
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(16, 19, 26, 0.80);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) 0;
  }
  .nav-logo {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-on-surface);
    text-decoration: none;
    letter-spacing: -0.5px;
  }
  .nav-logo:hover { color: var(--color-on-surface); }
  .nav-logo-accent { color: var(--color-primary); }
</style>
