      "parameters": {
        "jsCode": "const stripe = $node[\"GET Stripe Session\"].json;\n\nconst email = (stripe.customer_details && stripe.customer_details.email) || stripe.customer_email || \"\";\nconst nom = (stripe.customer_details && stripe.customer_details.name) || email || \"Client Kit\";\n\nconst body = {\n  parent: {\n    database_id: \"b7518473a44c49169f0b3fd8e91c4aca\"\n  },\n  properties: {\n    \"Nom Commerce\": {\n      title: [{ text: { content: nom } }]\n    },\n    \"Email\": {\n      email: email ? email : null\n    },\n    \"Session ID\": {\n      rich_text: [{ text: { content: stripe.id || \"\" } }]\n    },\n    \"Stripe Customer ID\": {\n      rich_text: [{ text: { content: stripe.customer || \"\" } }]\n    },\n    \"Type Achat\": {\n      select: { name: \"kit_seul\" }\n    },\n    \"Statut Client\": {\n      select: { name: \"Client Kit\" }\n    },\n    \"Source Lead\": {\n      select: { name: \"Landing\" }\n    },\n    \"Coupon AppliquÃ©\": {\n      select: { name: \"Aucun\" }\n    },\n    \"Montant PayÃ©\": {\n      number: stripe.amount_total ? stripe.amount_total / 100 : 49\n    },\n    \"CA GÃ©nÃ©rÃ©\": {\n      number: stripe.amount_total ? stripe.amount_total / 100 : 49\n    },\n    \"Order Bump Inclus\": {\n      checkbox: false\n    },\n    \"Webhook TraitÃ©\": {\n      checkbox: true\n    },\n    \"Date Conversion\": {\n      date: { start: new Date().toISOString().substring(0, 10) }\n    }\n  }\n};\n\nreturn [{ json: { notionBodyStr: JSON.stringify(body) } }];"
      },
