{
  "name": "EL — Prospection — Relances Quotidiennes J+2 & J+5",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 9 * * *"
            }
          ]
        }
      },
      "id": "22222222-0002-0002-0002-000000000001",
      "name": "① Schedule 9h quotidien",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        -2200,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst pad = n => String(n).padStart(2, '0');\nconst today = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())}`;\nconsole.log(`[Relances] Date du jour : ${today}`);\nreturn [{ json: { today } }];"
      },
      "id": "22222222-0002-0002-0002-000000000002",
      "name": "② Date du jour",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1960,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.notion.com/v1/databases/A_REMPLIR_NOTION_DB_PROSPECTS/query",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "notionApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"filter\":{\"and\":[{\"property\":\"Statut\",\"select\":{\"equals\":\"J0 - Envoyé\"}},{\"property\":\"Date J2 Due\",\"date\":{\"on_or_before\":\"{{.today}}\"}}]},\"page_size\":100}",
        "options": {}
      },
      "id": "22222222-0002-0002-0002-000000000003",
      "name": "③A Notion — Query J2 Pending",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        -1680,
        100
      ],
      "credentials": {
        "notionApi": {
          "id": "FJbYvS2QHuscfm50",
          "name": "Notion account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const resp = .first().json;\nconst results = resp.results || [];\nif (results.length === 0) { console.log(\"[J+2] Aucun prospect\"); return []; }\nconsole.log();\nreturn results.map(page => {\n  const props = page.properties;\n  return { json: {\n    notion_page_id: page.id,\n    email:         props['Email']?.email || '',\n    nom_entreprise: props['Nom Commerce']?.title?.[0]?.plain_text || '',\n    commune:       props['Commune']?.rich_text?.[0]?.plain_text || '',\n    score:         props['Score']?.number || 0,\n    note_google:   props['Note Google']?.number || 0,\n    nb_avis:       props['Nb Avis']?.number || 0,\n    activite:      props['Activité']?.rich_text?.[0]?.plain_text || '',\n  }};\n}).filter(item => item.json.email && item.json.email.includes('@'));"
      },
      "id": "22222222-0002-0002-0002-000000000004",
      "name": "④A Extrait Prospects J2",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1420,
        100
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.brevo.com/v3/smtp/email",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "api-key",
              "value": "A_REMPLIR_BREVO_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"sender\":{\"name\":\"Antoine — Expert Local\",\"email\":\"no-reply@expert-local.fr\"},\"to\":[{\"email\":\"{{.email}}\",\"name\":\"{{.nom_entreprise}}\"}],\"templateId\":A_REMPLIR_TEMPLATE_J2,\"params\":{\"NOM_COMMERCE\":\"{{.nom_entreprise}}\",\"COMMUNE\":\"{{.commune}}\",\"ACTIVITE\":\"{{.activite}}\",\"SCORE\":{{.score}},\"NOTE_GOOGLE\":{{.note_google}},\"NB_AVIS\":{{.nb_avis}}}}",
        "options": {}
      },
      "id": "22222222-0002-0002-0002-000000000005",
      "name": "⑤A Brevo — Envoi J+2",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        -1160,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "const brevoResp = .first().json;\nconst prev = .item.json;\nreturn [{ json: { ...prev, _brevo_ok: !!brevoResp.messageId } }];"
      },
      "id": "22222222-0002-0002-0002-000000000006",
      "name": "Merge J2 Brevo",
