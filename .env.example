# ══════════════════════════════════════════════
# Expert-Local.fr — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════

# ── Site ──
SITE_URL=https://expert-local.fr

# ── Stripe ──
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXX
# Price IDs (seront créés par API)
STRIPE_PRICE_KIT_49=price_XXXXXXX
STRIPE_PRICE_BUMP_19=price_XXXXXXX
STRIPE_PRICE_PRO_179=price_XXXXXXX
STRIPE_PRICE_VIP_497=price_XXXXXXX
# Coupon IDs
STRIPE_COUPON_DIAGNOSTIC24H=DIAGNOSTIC24H
STRIPE_COUPON_FLASH30=FLASH30

# ── n8n Webhooks (toutes server-side, jamais exposées côté client) ──
# URL du webhook diagnostic — utilisée par la Netlify Function submit-diagnostic
# En test : utiliser /webhook-test/... — En production : utiliser /webhook/...
N8N_WEBHOOK_DIAGNOSTIC_URL=https://n8n.example.com/webhook/expert-local-diagnostic
N8N_WEBHOOK_VERIFY_ACCESS=https://n8n.example.com/webhook/verify-access
N8N_WEBHOOK_STRIPE=https://n8n.example.com/webhook/stripe-events

# ── Brevo ──
BREVO_API_KEY=xkeysib-XXXXXXX

# ── Notion ──
NOTION_API_KEY=secret_XXXXXXX
NOTION_DB_PIPELINE=XXXXXXX

# ── Apify ──
APIFY_TOKEN=apify_api_XXXXXXX
APIFY_ACTOR_ID=XXXXXXX

# ── Gemini ──
GEMINI_API_KEY=XXXXXXX

# ── Admin ──
ADMIN_EMAIL=contact@expert-local.fr
